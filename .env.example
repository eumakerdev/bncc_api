# =============================================================================
# Plataforma Pública da BNCC API — configuração de ambiente
# Copie para `.env` e preencha. NENHUM default inseguro (Princípio V / FR-023):
# em ENVIRONMENT=production a aplicação FALHA RÁPIDO se SECRET_KEY for
# placeholder/ausente ou se ALLOWED_HOSTS contiver "*".
# =============================================================================

# --- Ambiente -----------------------------------------------------------------
ENVIRONMENT=development          # development | production
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- Segurança (OBRIGATÓRIO em produção) --------------------------------------
# Gere um valor forte: `python -c "import secrets; print(secrets.token_urlsafe(48))"`
# Em produção NÃO pode ser vazio nem o placeholder abaixo.
SECRET_KEY=change-me-dev-only-not-for-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Lista de hosts/origens permitidos. Em produção NÃO pode ser ["*"].
# Ex.: ALLOWED_HOSTS=["https://bncc.api.br","https://api-bncc.web.app"]
ALLOWED_HOSTS=["*"]
# Content-Security-Policy: false (padrão) = emite a CSP em modo Report-Only, que
# NÃO bloqueia nada, só reporta violações ao console — rollout sem risco de quebrar
# a referência Scalar (/docs) ou as páginas SSR. Vire para true (bloqueante) apenas
# após validar /, /guia, /docs e /portal num navegador. Ver docs/seguranca-endurecimento.md.
CSP_ENFORCE=false

# URL canônica pública (SEO/e-mail). Vazio em dev = deriva do request.
# Em produção aponte para o domínio primário para canonical/OG/sitemap corretos
# atrás do Firebase Hosting (que entrega o Host interno do Cloud Run ao container).
# Ex.: SITE_URL=https://bncc.api.br
SITE_URL=

# --- Banco da plataforma (contas/keys/uso) ------------------------------------
# Dev: SQLite async. Prod: trocar por postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./data/platform.db

# --- Dados oficiais da BNCC (snapshot versionado, read-only) ------------------
BNCC_DATA_PATH=./data/bncc_v1.json
CHROMADB_PATH=./data/chromadb

# --- E-mail (verificação de conta) --------------------------------------------
# EMAIL_BACKEND=console em dev (loga o link); smtp em produção (via Brevo).
EMAIL_BACKEND=console
EMAIL_FROM=no-reply@bncc.api.br
EMAIL_VERIFICATION_BASE_URL=http://localhost:8000/portal/verify-email
EMAIL_TOKEN_EXPIRE_MINUTES=1440
# Brevo (ex-Sendinblue): host fixo abaixo; login/senha vêm do painel SMTP do Brevo.
# Em produção estes dois entram pelo Secret Manager (ver deploy/cloudrun.ps1), nunca em env plano.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- Cotas / Rate limiting ----------------------------------------------------
RATE_LIMIT_DETERMINISTIC_PER_MIN=60
RATE_LIMIT_DETERMINISTIC_BURST=10
RATE_LIMIT_AI_PER_MIN=20
RATE_LIMIT_AI_PER_DAY=500
RATE_LIMIT_OAUTH_PER_MIN=10

# --- Login social (OAuth 2.0 — OPCIONAL; desabilita se não configurado) -------
# Registre o app OAuth em cada provedor e configure o redirect_uri:
#   Google  -> {OAUTH_REDIRECT_BASE_URL}/portal/auth/google/callback
#   GitHub  -> {OAUTH_REDIRECT_BASE_URL}/portal/auth/github/callback
# Em produção, os *_SECRET entram pelo Secret Manager, nunca em env plano.
# Ambos os campos de um provedor devem ser definidos juntos (id + secret).
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- IA / Busca semântica (OPCIONAL — degrada graciosamente se ausente) -------
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Modelo multilíngue (a BNCC é em português; modelos só-inglês casam componentes errados)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
LLM_MODEL=gpt-3.5-turbo
# Calibrado para o modelo multilíngue (acertos relevantes pontuam ~0,50–0,72)
SIMILARITY_THRESHOLD=0.45
MAX_SEARCH_RESULTS=10
AI_REQUEST_TIMEOUT_SECONDS=15
AI_MAX_OUTPUT_TOKENS=800
